# ── Integration modes ──────────────────────────────────────────────────────────
# Controls whether each external system uses a real API or a local mock.
# Default is "mock" for every integration — the project runs without credentials.
# Set to "live" to enable real API calls; all other values are treated as "mock".
INTEGRATION_CONFLUENCE_MODE=mock   # mock | live
INTEGRATION_GITHUB_MODE=mock       # mock | live
INTEGRATION_AWS_MODE=mock          # mock | live  (see AWS section below)
INTEGRATION_HARNESS_MODE=mock      # mock | live  (see Harness section below)

# ── Safety (live deploys only) ─────────────────────────────────────────────────
# When false (default), AWS and Harness live modes run in DRY-RUN:
# they authenticate and validate the real call, log exactly what they WOULD do,
# but do NOT execute any mutating action (no ECS update, no Harness trigger).
# Set to "true" only after verifying credentials with the check_*.py scripts.
SAFETY_ALLOW_LIVE_DEPLOYS=false

# ── LLM (OpenAI-compatible; works with OpenAI, Azure OpenAI, local vLLM, etc.) ─
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Override per-agent model if desired:
# AGENT_MODEL=gpt-4o

# ── Embeddings ─────────────────────────────────────────────────────────────────
# Model used by src/knowledge/rag_index.py to embed documents and queries.
EMBEDDING_MODEL=text-embedding-3-large

# ── GitHub (used when INTEGRATION_GITHUB_MODE=live) ────────────────────────────
# Personal access token — needs pull_requests:read and contents:read permissions.
# Fine-grained tokens: https://github.com/settings/tokens?type=beta
# Classic tokens:      https://github.com/settings/tokens
GITHUB_TOKEN=
# Target repository for PR diff fetches (owner/repo format)
GITHUB_REPO=owner/repo

# ── Confluence (used when INTEGRATION_CONFLUENCE_MODE=live) ────────────────────
# Generate API token at: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_SITE_URL=https://your-org.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=
# Space key where release pages are published (visible in the space URL)
CONFLUENCE_SPACE_KEY=ENG
# Numeric ID of the parent page (from the page URL: /pages/<ID>)
# Leave blank to create pages at the space root
CONFLUENCE_PARENT_PAGE_ID=

# ── Jira (Release Scribe posts deployment comments) ────────────────────────────
# Uses the same ATLASSIAN_* credentials above
# JIRA_PROJECT_KEY=PLAT    # target project for release comments

# ── AWS CloudWatch (used when INTEGRATION_AWS_MODE=live) ───────────────────────
# IAM credentials — needs cloudwatch:GetMetricData + cloudwatch:GetMetricStatistics.
# Least-privilege: read-only CloudWatch metrics access is sufficient.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=       # for temporary credentials / assumed roles
AWS_REGION=us-east-1
# Sandbox scope — SandboxViolationError is raised if the service name does not
# match. Set to the ECS service/cluster you want to monitor.
AWS_SANDBOX_CLUSTER=
AWS_SANDBOX_SERVICE=
# CloudWatch namespace and dimension overrides (defaults work for ALB/ECS)
# AWS_CLOUDWATCH_NAMESPACE=AWS/ApplicationELB

# ── Harness (used when INTEGRATION_HARNESS_MODE=live) ─────────────────────────
# Personal Access Token or Service Account token (pipeline:execute permission).
# Generate at: https://app.harness.io → Account Settings → API Keys
HARNESS_API_KEY=
HARNESS_ACCOUNT_ID=
HARNESS_ORG_ID=default
HARNESS_PROJECT_ID=
HARNESS_PIPELINE_ID=
# Sandbox scope — HarnessSandboxViolationError raised if the project does not
# match. Defaults to HARNESS_PROJECT_ID if not set.
HARNESS_SANDBOX_PROJECT=
# HARNESS_BASE_URL=https://app.harness.io  # override for self-hosted

# ── OPA Policy Engine ──────────────────────────────────────────────────────────
OPA_URL=http://localhost:8181

# ── Mock AWS (Canary Orchestrator + SLO Sentinel use this in mock mode) ────────
AWS_MOCK_URL=http://localhost:8080

# ── Microsoft Teams (Release Scribe notification) ──────────────────────────────
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# ── OpenTelemetry ──────────────────────────────────────────────────────────────
# Leave blank to fall back to ConsoleSpanExporter (development).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=release-pilot

# ── SLO Sentinel ───────────────────────────────────────────────────────────────
# How often the sentinel polls CloudWatch / Mock AWS for metrics.
SENTINEL_POLL_INTERVAL_SECONDS=30

# ── Demo flags ─────────────────────────────────────────────────────────────────
DEMO_MODE=true
LOG_LEVEL=INFO
