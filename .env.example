# ── Integration modes ──────────────────────────────────────────────────────────
# Controls whether each external system uses a real API or a local mock.
# Default is "mock" for every integration — the project runs without credentials.
# Set to "live" to enable real API calls; all other values are treated as "mock".
#
# AWS and Harness are always mock — real deployment infrastructure is
# intentionally out of scope for this project.
INTEGRATION_CONFLUENCE_MODE=mock   # mock | live
INTEGRATION_GITHUB_MODE=mock       # mock | live

# ── LLM (OpenAI-compatible; works with OpenAI, Azure OpenAI, local vLLM, etc.) ─
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Override per-agent model if desired:
# AGENT_MODEL=gpt-4o

# ── Embeddings ─────────────────────────────────────────────────────────────────
# Model used by src/knowledge/rag_index.py to embed documents and queries.
EMBEDDING_MODEL=text-embedding-3-large

# ── GitHub (used when INTEGRATION_GITHUB_MODE=live) ────────────────────────────
# Personal access token — needs pull_requests:read and contents:read permissions.
# Fine-grained tokens: https://github.com/settings/tokens?type=beta
# Classic tokens:      https://github.com/settings/tokens
GITHUB_TOKEN=
# Target repository for PR diff fetches (owner/repo format)
GITHUB_REPO=owner/repo

# ── Confluence (used when INTEGRATION_CONFLUENCE_MODE=live) ────────────────────
# Generate API token at: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_SITE_URL=https://your-org.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=
# Space key where release pages are published (visible in the space URL)
CONFLUENCE_SPACE_KEY=ENG
# Numeric ID of the parent page (from the page URL: /pages/<ID>)
# Leave blank to create pages at the space root
CONFLUENCE_PARENT_PAGE_ID=

# ── Jira (Release Scribe posts deployment comments) ────────────────────────────
# Uses the same ATLASSIAN_* credentials above
# JIRA_PROJECT_KEY=PLAT    # target project for release comments

# ── OPA Policy Engine ──────────────────────────────────────────────────────────
OPA_URL=http://localhost:8181

# ── Mock AWS (Canary Orchestrator + SLO Sentinel use this in demo mode) ────────
AWS_MOCK_URL=http://localhost:8080

# ── Microsoft Teams (Release Scribe notification) ──────────────────────────────
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# ── OpenTelemetry ──────────────────────────────────────────────────────────────
# Leave blank to fall back to ConsoleSpanExporter (development).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=release-pilot

# ── SLO Sentinel ───────────────────────────────────────────────────────────────
# How often the sentinel polls CloudWatch / Mock AWS for metrics.
SENTINEL_POLL_INTERVAL_SECONDS=30

# ── Demo flags ─────────────────────────────────────────────────────────────────
DEMO_MODE=true
LOG_LEVEL=INFO
